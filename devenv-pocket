patch_gradle_cache() {
    echo -e "\n${CLR_TITLE}Executing Gradle Cache JARs Patch...${CLR_RESET}"
    echo -e "${CLR_INFO}[➔]${CLR_RESET} Searching Gradle caches for x86_64 aapt2 packages..."
    
    local jar_count=0
    if [ -d "$HOME/.gradle" ]; then
        find "$HOME/.gradle" -name "aapt2-*-linux.jar" 2>/dev/null | while read -r jar; do
            echo -e "  Patching: $jar"
            jar -u -f "$jar" -C /usr/bin aapt2 2>/dev/null
            ((jar_count++))
        done
        echo -e "${CLR_VAL}[✔]${CLR_RESET} Patched $jar_count active Gradle JAR containers."
    else
        echo -e "${CLR_WARN}[!] Warning:${CLR_RESET} No ~/.gradle directory found. Run a flutter build first."
    fi
}

run_diagnostics() {
    print_header
    get_system_info
    
    echo -e "\n${CLR_TITLE}Component Check Details:${CLR_RESET}"
    draw_line "─"
    
    printf " %-30s : " "Base tools package count"
    local base_pkgs=(curl git unzip xz-utils zip wget nodejs npm openjdk-17-jdk android-tools-adb aapt clang cmake ninja-build lld binutils python3 python3-pip software-properties-common)
    local installed_count=0
    for pkg in "${base_pkgs[@]}"; do
        if check_apt_pkg "$pkg"; then ((installed_count++)); fi
    done
    echo -e "$installed_count/${#base_pkgs[@]} packages installed"
    
    printf " %-30s : " "pnpm Package Manager"
    if command -v pnpm >/dev/null 2>&1; then echo -e "${CLR_VAL}Available ($(pnpm -v))${CLR_RESET}"; else echo -e "${CLR_ERR}Missing${CLR_RESET}"; fi
    
    printf " %-30s : " "Chromium Browser wrapper"
    if [ -f "/usr/local/bin/chromium-wrapper" ]; then echo -e "${CLR_VAL}Active${CLR_RESET}"; else echo -e "${CLR_ERR}Missing${CLR_RESET}"; fi
    
    printf " %-30s : " "Flutter SDK binaries"
    if command -v flutter >/dev/null 2>&1; then echo -e "${CLR_VAL}Installed ($(flutter --version | head -n 1))${CLR_RESET}"; else echo -e "${CLR_ERR}Missing${CLR_RESET}"; fi
    
    printf " %-30s : " "Android SDK Manager"
    if [ -f "$TOOLS_DIR/android-sdk/cmdline-tools/latest/bin/sdkmanager" ]; then echo -e "${CLR_VAL}Installed${CLR_RESET}"; else echo -e "${CLR_ERR}Missing${CLR_RESET}"; fi
    
