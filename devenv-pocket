    if [ $t_count -eq 3 ]; then echo -e "${CLR_VAL}All Templates Configured ($t_count/3)${CLR_RESET}"; else echo -e "${CLR_WARN}Partially Cached ($t_count/3)${CLR_RESET}"; fi
    
