# ==============================================================================
# MAIN EXECUTION ENTRYPOINT
# ==============================================================================

# 1. Pre-parse optional CLI flags from parameters list
NEW_ARGS=()
for arg in "$@"; do
    case "$arg" in
        --terminal|-t)
            CLI_MODE="terminal"
            ;;
        --graphical|-g)
            CLI_MODE="graphical"
            ;;
        --editor=*|-e=*)
            CLI_EDITOR="${arg#*=}"
            ;;
        --offline|-o)
            CLI_OFFLINE="true"
            ;;
        *)
            NEW_ARGS+=("$arg")
            ;;
    esac
done
# Re-set positional parameters to the filtered arguments
set -- "${NEW_ARGS[@]}"

# 2. Architecture Check Warnings
HOST_ARCH=$(uname -m)
if [ "$HOST_ARCH" != "aarch64" ] && [ "$HOST_ARCH" != "arm64" ]; then
    echo -e "${CLR_WARN}[!] ARCHITECTURE WARNING:${CLR_RESET}"
    echo -e "    This tool compiles and configures tools specifically for ARM64 architectures (aarch64)."
    echo -e "    Your CPU reports: ${CLR_ERR}$HOST_ARCH${CLR_RESET}."
    echo -e "    If you run this on a standard x86-64 machine, some compiler features (like NDK & AAPT overrides) will break."
    echo -ne "    Do you want to continue running the script? (y/N): "
    read -r response
    if [[ ! "$response" =~ ^[Yy]$ ]]; then
        echo -e "${CLR_ERR}Execution cancelled.${CLR_RESET}"
        exit 1
    fi
fi

# 3. Self-Registration on System PATH
SCRIPT_PATH=$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || realpath "${BASH_SOURCE[0]}" 2>/dev/null)
if [ -n "$SCRIPT_PATH" ]; then
    if [ "$SCRIPT_PATH" != "/usr/local/bin/devenv-pocket" ] && [ -d "/usr/local/bin" ]; then
        if [ ! -L "/usr/local/bin/devenv-pocket" ] && [ ! -f "/usr/local/bin/devenv-pocket" ]; then
            echo -e "${CLR_INFO}[➔] Registering devenv-pocket globally in /usr/local/bin/devenv-pocket...${CLR_RESET}"
            $SUDO ln -sf "$SCRIPT_PATH" "/usr/local/bin/devenv-pocket" 2>/dev/null
            $SUDO chmod +x "$SCRIPT_PATH" 2>/dev/null
            $SUDO chmod +x "/usr/local/bin/devenv-pocket" 2>/dev/null
        fi
    fi
fi

# 4. CLI Arguments Routing
if [ $# -gt 0 ]; then
    case "$1" in
        help|--help|-h)
            print_cli_help
            exit 0
            ;;
        status|check|diagnostics)
            run_diagnostics
            exit 0
            ;;
        patch)
            patch_gradle_cache
            exit 0
            ;;
        ftpstart)
            start_ftp_server
            exit 0
            ;;
        ftpstop)
            stop_ftp_server
            exit 0
            ;;
        create)
            create_project_from_template "$2" "$3"
            exit 0
            ;;
        offline)
            toggle_offline_mode "$2"
            exit 0
            ;;
        install)
            if [ -z "$2" ]; then
                echo -e "${CLR_ERR}[✘] Error: Specify an environment to install (node, flutter, postgres, all).${CLR_RESET}"
                echo -e "Usage: devenv-pocket install <env>"
                exit 1
            fi
            
            # Unattended mode default mode to terminal if not provided
            if [ -z "$CLI_MODE" ]; then
                CLI_MODE="terminal"
            fi
            if [ -z "$CLI_EDITOR" ]; then
                CLI_EDITOR="both"
            fi
            
            case "$2" in
                node) install_node_web_env ;;
                flutter) install_flutter_android_env ;;
                postgres) install_postgresql_env ;;
                all)
                    install_node_web_env
                    install_flutter_android_env
                    install_postgresql_env
                    ;;
                *)
                    echo -e "${CLR_ERR}[✘] Error: Unknown environment '$2'. Available: node, flutter, postgres, all.${CLR_RESET}"
                    exit 1
                    ;;
            esac
            exit 0
            ;;
        remove|uninstall)
            if [ -z "$2" ]; then
                echo -e "${CLR_ERR}[✘] Error: Specify an environment to remove (node, flutter, postgres, all).${CLR_RESET}"
                echo -e "Usage: devenv-pocket remove <env>"
                exit 1
            fi
            case "$2" in
                node) remove_node_web_env ;;
                flutter) remove_flutter_android_env ;;
                postgres) remove_postgresql_env ;;
                all)
                    remove_node_web_env
                    remove_flutter_android_env
                    remove_postgresql_env
                    ;;
                *)
                    echo -e "${CLR_ERR}[✘] Error: Unknown environment '$2'. Available: node, flutter, postgres, all.${CLR_RESET}"
                    exit 1
                    ;;
            esac
            exit 0
            ;;
        *)
            echo -e "${CLR_ERR}[✘] Error: Unknown command '$1'.${CLR_RESET}"
            echo -e "Type ${CLR_MENU}devenv-pocket help${CLR_RESET} to view all available commands."
            exit 1
            ;;
    esac
fi

# Run the interactive menu loop if no arguments are passed
main_menu
