check_flutter_android_status() {
    local missing_base=0
    local base_pkgs=(openjdk-17-jdk android-tools-adb aapt clang cmake ninja-build lld binutils curl git unzip xz-utils zip wget)
    for pkg in "${base_pkgs[@]}"; do
        if ! check_apt_pkg "$pkg"; then
            ((missing_base++))
        fi
    done
    
    local has_flutter=0
    if [ -d "$TOOLS_DIR/flutter" ] && command -v flutter >/dev/null 2>&1; then
        has_flutter=1
    fi
    
    local has_sdk=0
    if [ -f "$TOOLS_DIR/android-sdk/cmdline-tools/latest/bin/sdkmanager" ]; then
        has_sdk=1
    fi
    
    local has_ndk=0
    if [ -d "$TOOLS_DIR/android-sdk/ndk/28.2.13676358" ]; then
        has_ndk=1
    fi
    
    if [ $missing_base -eq 0 ] && [ $has_flutter -eq 1 ] && [ $has_sdk -eq 1 ] && [ $has_ndk -eq 1 ]; then
        echo -e "${CLR_VAL}[Fully Installed]${CLR_RESET}"
    elif [ $missing_base -eq ${#base_pkgs[@]} ] && [ $has_flutter -eq 0 ] && [ $has_sdk -eq 0 ] && [ $has_ndk -eq 0 ]; then
        echo -e "${CLR_ERR}[Not Installed]${CLR_RESET}"
    else
        echo -e "${CLR_WARN}[Partially Installed]${CLR_RESET}"
    fi
}

configure_offline_flutter_templates() {
    echo -e "\n${CLR_TITLE}Setting up Offline Flutter & Android Caches...${CLR_RESET}"
    echo -e "This involves initializing a template and running a full test compile."
    echo -e "${CLR_WARN}[!] Storage Note:${CLR_RESET} Requires downloading and caching ~700 MB of dependencies."
    echo -e "This can take up to 3-5 minutes depending on your internet connection speed."
    
    mkdir -p "$TEMPLATES_DIR"
    local f_dir="$TEMPLATES_DIR/flutter-starter"
    
    if [ ! -d "$f_dir" ]; then
        # Create Starter
        run_with_spinner "cd '$TEMPLATES_DIR' && flutter create flutter-starter --org com.devenv.offline" "Creating Flutter starter template"
        
        # Patch API overrides
        sed -i 's/compileSdk = flutter.compileSdkVersion/compileSdk = 34/' "$f_dir/android/app/build.gradle.kts"
        sed -i 's/targetSdk = flutter.targetSdkVersion/targetSdk = 34/' "$f_dir/android/app/build.gradle.kts"
        echo -e "  Applied compileSdk=34 & targetSdk=34 overrides to build.gradle."
        
        # Populate pub cache
        run_with_spinner "cd '$f_dir' && flutter pub get" "Caching Dart/Flutter library dependencies"
        
        # Pre-build to populate Gradle maven caches
        echo -e "  Running dry-run debug compilation (populates Gradle wrapper and maven libraries)..."
        run_with_spinner "cd '$f_dir' && flutter build apk --debug" "Compiling template (populating maven cache)"
    else
        echo -e "${CLR_VAL}[✔]${CLR_RESET} flutter-starter template already configured."
    fi
}

install_flutter_android_env() {
    local mode
    mode=$(select_execution_mode)
    
    echo -e "\n${CLR_TITLE}Installing Flutter & Android Development Profile (${mode} mode)...${CLR_RESET}"
    echo -e "${CLR_WARN}[!] Storage Note:${CLR_RESET} Requires ~1.5 GB download / ~5.5 GB disk space."
    echo -e "${CLR_WARN}[!] Installing in:${CLR_RESET} $TOOLS_DIR (SDKs & tools)"
    echo -e "${CLR_WARN}[!] Warnings:${CLR_RESET} A custom ARM64 build of NDK r28c will be downloaded (~171 MB)."
    
    # Ensure tools directory exists
    mkdir -p "$TOOLS_DIR"
    
    # 1. Update Package List & Install Base System Tools
    echo -e "\n--- Step 1: Upgrading package manager & installing dependencies ---"
    run_with_spinner "$SUDO apt update" "Syncing repositories"
    
    local base_pkgs=(openjdk-17-jdk android-tools-adb aapt clang cmake ninja-build lld binutils curl git unzip xz-utils zip wget)
    if [ "$mode" = "graphical" ]; then
        base_pkgs+=(software-properties-common)
    fi
    
    local install_list=()
    for pkg in "${base_pkgs[@]}"; do
        if ! check_apt_pkg "$pkg"; then
            install_list+=("$pkg")
        fi
    done
    
    if [ ${#install_list[@]} -gt 0 ]; then
        run_with_spinner "$SUDO apt install -y ${install_list[*]}" "Installing developer packages (${install_list[*]})"
    else
        echo -e "${CLR_VAL}[✔]${CLR_RESET} Base packages already installed."
    fi
    
    # Setup Dockerenv to suppress Flutter root warnings inside proot container
    $SUDO touch /.dockerenv 2>/dev/null
    
    # 2. Setup Chromium (PPA) for Flutter Web output (only if graphical mode is chosen)
    if [ "$mode" = "graphical" ]; then
        echo -e "\n--- Step 2: Web platform target setup (Chromium PPA) ---"
        if ! check_apt_pkg "chromium"; then
            run_with_spinner "$SUDO add-apt-repository -y ppa:xtradeb/apps" "Adding PPA"
            run_with_spinner "$SUDO apt update" "Updating packages"
            run_with_spinner "$SUDO apt install -y chromium" "Installing Chromium"
        fi
        
        # Write Chromium pin priorities
        if [ ! -f "/etc/apt/preferences.d/xtradeb-pin" ]; then
            local pin_content="Package: *\nPin: release o=LP-PPA-xtradeb-apps\nPin-Priority: 1\n\nPackage: chromium\nPin: release o=LP-PPA-xtradeb-apps\nPin-Priority: 500\n"
            echo -e "$pin_content" | $SUDO tee /etc/apt/preferences.d/xtradeb-pin >/dev/null
        fi
        
        # Create Chromium wrapper file for root sandbox restrictions in proot
        if [ ! -f "/usr/local/bin/chromium-wrapper" ]; then
            local wrapper_content="#!/bin/bash\nexec chromium --no-sandbox --disable-dev-shm-usage --no-first-run \"\$@\"\n"
            echo -e "$wrapper_content" | $SUDO tee /usr/local/bin/chromium-wrapper >/dev/null
            $SUDO chmod +x /usr/local/bin/chromium-wrapper
        fi
        append_block_to_bashrc "CHROMIUM" "export CHROME_EXECUTABLE=/usr/local/bin/chromium-wrapper"
    fi
    
    # 3. Download & Install Flutter SDK
    echo -e "\n--- Step 3: Installing Flutter SDK (Git Stable) ---"
    if [ ! -d "$TOOLS_DIR/flutter" ]; then
        run_with_spinner "git clone https://github.com/flutter/flutter.git -b stable $TOOLS_DIR/flutter" "Cloning Flutter SDK (Branch: stable)"
    else
        echo -e "${CLR_VAL}[✔]${CLR_RESET} Flutter SDK folder already exists."
    fi
    
    # 4. Download & Install Android Command Line Tools
    echo -e "\n--- Step 4: Installing Android SDK Command Line Tools ---"
    local sdk_root="$TOOLS_DIR/android-sdk"
    local cli_zip="$sdk_root/cmdline-tools/commandlinetools-linux.zip"
    
    if [ ! -f "$sdk_root/cmdline-tools/latest/bin/sdkmanager" ]; then
        mkdir -p "$sdk_root/cmdline-tools"
        
        # Download Android Command Line Tools
        download_file \
            "https://dl.google.com/android/repository/commandlinetools-linux-13114758_latest.zip" \
            "$cli_zip" \
            "Android SDK Command Line Tools"
        
        # Extract files
        echo -e "${CLR_INFO}[➔]${CLR_RESET} Extracting command line tools..."
        unzip -q "$cli_zip" -d "$sdk_root/cmdline-tools"
        rm -f "$cli_zip"
        
        # Move directory to correct name structure
        mv "$sdk_root/cmdline-tools/cmdline-tools" "$sdk_root/cmdline-tools/latest"
        echo -e "${CLR_VAL}[✔]${CLR_RESET} Successfully configured Command Line Tools structure."
    else
        echo -e "${CLR_VAL}[✔]${CLR_RESET} Command Line Tools already exists."
    fi
    
    # Export SDK environment paths to ~/.bashrc
    local flutter_block='export PATH="$PATH:$HOME/tools/flutter/bin"
export ANDROID_HOME="$HOME/tools/android-sdk"
export ANDROID_SDK_ROOT="$HOME/tools/android-sdk"
export PATH="$PATH:$ANDROID_SDK_ROOT/cmdline-tools/latest/bin"
export PATH="$PATH:$ANDROID_SDK_ROOT/platform-tools"
export PATH="$PATH:$HOME/tools"'
    
    append_block_to_bashrc "FLUTTER" "$flutter_block"
    
    # Apply paths dynamically to the installer subshell
    export ANDROID_HOME="$sdk_root"
    export ANDROID_SDK_ROOT="$sdk_root"
    export PATH="$PATH:$TOOLS_DIR/flutter/bin:$sdk_root/cmdline-tools/latest/bin:$sdk_root/platform-tools"
    
    # 5. Licensing and Android Components
    echo -e "\n--- Step 5: Accepting Google Android Licenses ---"
    yes | sdkmanager --licenses >/dev/null
    
    echo -e "\n--- Step 6: Installing platform-tools, platforms;android-34, build-tools;34.0.0 ---"
    sdkmanager "platform-tools" "platforms;android-34" "build-tools;34.0.0"
    
    # 6. Apply ARM64 Binary Overrides/Patches
    echo -e "\n--- Step 7: Overriding SDK x86_64 binaries with local ARM64 symbols ---"
    local platform_tools_path="$sdk_root/platform-tools"
    local build_tools_path="$sdk_root/build-tools/34.0.0"
    
    if [ -f "$platform_tools_path/adb" ]; then
        ln -sf "$(which adb)" "$platform_tools_path/adb"
        echo -e "    Symlinked local ARM64 adb -> $platform_tools_path/adb"
    fi
    
    if [ -d "$build_tools_path" ]; then
        ln -sf "$(which aapt)" "$build_tools_path/aapt"
        ln -sf "$(which aapt2)" "$build_tools_path/aapt2"
        echo -e "    Symlinked local ARM64 aapt/aapt2 -> build-tools/34.0.0"
    fi
    
    mkdir -p "$sdk_root/cmake/3.22.1/bin"
    ln -sf "$(which cmake)" "$sdk_root/cmake/3.22.1/bin/cmake"
    ln -sf "$(which ninja)" "$sdk_root/cmake/3.22.1/bin/ninja"
    echo -e "    Symlinked local cmake/ninja -> $sdk_root/cmake/3.22.1/bin"
    
    # 7. Download custom ARM64 Android NDK Build (r28c)
    echo -e "\n--- Step 8: Installing custom ARM64 NDK (r28c) ---"
    local ndk_base="$sdk_root/ndk"
    local ndk_target_ver="28.2.13676358"
    local ndk_tar="$ndk_base/android-ndk-r28c-aarch64.tar.xz"
    
    if [ ! -d "$ndk_base/$ndk_target_ver" ]; then
        mkdir -p "$ndk_base"
        download_file \
            "https://github.com/HomuHomu833/android-ndk-custom/releases/download/r28/android-ndk-r28c-aarch64-linux-android.tar.xz" \
            "$ndk_tar" \
            "ARM64 NDK r28c Archive"
            
        echo -e "${CLR_INFO}[➔]${CLR_RESET} Decompressing NDK custom port... This can take up to 2-3 minutes."
        tar -xf "$ndk_tar" -C "$ndk_base"
        rm -f "$ndk_tar"
        
        mv "$ndk_base/android-ndk-r28c" "$ndk_base/$ndk_target_ver"
        echo -e "${CLR_VAL}[✔]${CLR_RESET} Custom NDK extraction completed successfully."
    else
        echo -e "${CLR_VAL}[✔]${CLR_RESET} NDK $ndk_target_ver already installed."
    fi
    
    local toolchain_file="$ndk_base/$ndk_target_ver/build/cmake/android.toolchain.cmake"
    if [ -f "$toolchain_file" ]; then
        sed -i 's/if(CMAKE_HOST_SYSTEM_NAME STREQUAL Linux)/if(CMAKE_HOST_SYSTEM_NAME STREQUAL Android)\nset(ANDROID_HOST_TAG linux-aarch64)\nelseif(CMAKE_HOST_SYSTEM_NAME STREQUAL Linux)/g' \
            "$toolchain_file"
        echo -e "    Patched Android cmake toolchain file layout."
    fi
    
    # Apply SDK configurations to Flutter
    flutter config --android-sdk "$sdk_root"
    
    # 8. Handle Editor Configuration in Terminal mode
    if [ "$mode" = "terminal" ]; then
        local editor
        editor=$(select_terminal_editor)
        
        if [ "$editor" = "codeserver" ] || [ "$editor" = "both" ]; then
            echo -e "\n--- Step 9: Installing code-server (VS Code in Android browser) ---"
            if ! command -v code-server >/dev/null 2>&1; then
                echo -e "${CLR_INFO}[➔]${CLR_RESET} Fetching and executing code-server official installer script..."
                curl -fsSL https://code-server.dev/install.sh | $SUDO sh
            else
                echo -e "${CLR_VAL}[✔]${CLR_RESET} code-server is already installed."
            fi
            
            local cs_func='# cs - start code-server and open the browser automatically
cs() {
  local path="${1:-.}"
  local port=8080
  while true; do
    if ! nc -z localhost "$port" > /dev/null 2>&1; then
      break
    fi
    port=$((port + 1))
  done
  echo "Port $port is free, starting code-server..."
  code-server --port "$port" --auth none "$path" &
  sleep 2
  local url="http://localhost:$port"
  echo "Opening: $url"
  termux-open-url "$url" 2>/dev/null || echo -e "\e[33mPlease open this URL in your Android browser: $url\e[0m"
}'
            append_block_to_bashrc "CODESERVER" "$cs_func"
        fi
        
        if [ "$editor" = "ftp" ] || [ "$editor" = "both" ]; then
            echo -e "\n--- Step 10: Configuring Python FTP Server (for Acode) ---"
            start_ftp_server
            
            echo -ne "\n${CLR_MENU}[?]${CLR_RESET} Run FTP server automatically on terminal session start? (y/N): "
            read -r run_boot
            if [[ "$run_boot" =~ ^[Yy]$ ]]; then
                append_block_to_bashrc "FTPBOOT" "python3 -m pyftpdlib -p 2121 -w -d $PROJECTS_DIR >/tmp/devenv_ftp.log 2>&1 &"
                echo -e "${CLR_VAL}[✔] Registered automatic FTP server start on session login.${CLR_RESET}"
            fi
        fi
        
        show_acode_direct_path_tip
        
        # Print Wireless Debugging Help details
        echo -e "\n${CLR_INFO}┌──────────────────────────────────────────────────────────────────────┐${CLR_RESET}"
        echo -e "${CLR_INFO}│${CLR_RESET} ${CLR_TITLE}HEADLESS MOBILE DEVICE DEBUGGING GUIDE${CLR_RESET}                                ${CLR_INFO}│${CLR_RESET}"
        echo -e "${CLR_INFO}├──────────────────────────────────────────────────────────────────────┤${CLR_RESET}"
        echo -e "${CLR_INFO}│${CLR_RESET} 1. Open your Android Settings -> Developer Options                    ${CLR_INFO}│${CLR_RESET}"
        echo -e "${CLR_INFO}│${CLR_RESET} 2. Toggle 'Wireless debugging' to ON                                  ${CLR_INFO}│${CLR_RESET}"
        echo -e "${CLR_INFO}│${CLR_RESET} 3. Tap 'Pair device with pairing code'                                ${CLR_INFO}│${CLR_RESET}"
        echo -e "${CLR_INFO}│${CLR_RESET} 4. Pair inside proot-distro shell:                                    ${CLR_INFO}│${CLR_RESET}"
        echo -e "${CLR_INFO}│${CLR_RESET}    ${CLR_MENU}adb pair 127.0.0.1:PAIRING_PORT${CLR_RESET}                                   ${CLR_INFO}│${CLR_RESET}"
        echo -e "${CLR_INFO}│${CLR_RESET} 5. Connect to the MAIN port listed on settings dashboard:             ${CLR_INFO}│${CLR_RESET}"
        echo -e "${CLR_INFO}│${CLR_RESET}    ${CLR_MENU}adb connect 127.0.0.1:MAIN_PORT${CLR_RESET}                                 ${CLR_INFO}│${CLR_RESET}"
        echo -e "${CLR_INFO}│${CLR_RESET} 6. Confirm device detection and execute hot reload run:              ${CLR_INFO}│${CLR_RESET}"
        echo -e "${CLR_INFO}│${CLR_RESET}    ${CLR_MENU}flutter devices && flutter run${CLR_RESET}                                  ${CLR_INFO}│${CLR_RESET}"
        echo -e "${CLR_INFO}└──────────────────────────────────────────────────────────────────────┘${CLR_RESET}"
    fi
    
    # 9. Offer offline cache pre-compilation
    local enable_offline="$CLI_OFFLINE"
    if [ -z "$enable_offline" ]; then
        echo -ne "\n${CLR_MENU}[?]${CLR_RESET} Pre-populate Android SDK & Gradle Caches for Offline Development? (y/N): "
        read -r enable_offline
    fi
    if [[ "$enable_offline" =~ ^([Yy]|true)$ ]]; then
        configure_offline_flutter_templates
    fi
    
    # Trigger first doctor run
    echo -e "\n--- Step 11: Testing components via 'flutter doctor' ---"
    flutter doctor
    
    mkdir -p "$PROJECTS_DIR"
    
    echo -e "\n${CLR_VAL}✔ Flutter & Android App Suite setup complete!${CLR_RESET}"
    echo -e "${CLR_WARN}[!] Action Needed:${CLR_RESET} Please run: ${CLR_MENU}source ~/.bashrc${CLR_RESET} to enable settings."
}

