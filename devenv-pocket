check_postgresql_status() {
    if check_apt_pkg "postgresql" && [ -f "/var/lib/postgresql/17/main/PG_VERSION" ]; then
        echo -e "${CLR_VAL}[Fully Installed]${CLR_RESET}"
    elif ! check_apt_pkg "postgresql" && [ ! -d "/var/lib/postgresql/17/main" ]; then
        echo -e "${CLR_ERR}[Not Installed]${CLR_RESET}"
    else
        echo -e "${CLR_WARN}[Partially Installed]${CLR_RESET}"
    fi
}

install_postgresql_env() {
    echo -e "\n${CLR_TITLE}Installing PostgreSQL Database Server...${CLR_RESET}"
    echo -e "${CLR_WARN}[!] Storage Note:${CLR_RESET} Requires ~35 MB download / ~100 MB disk space."
    echo -e "${CLR_WARN}[!] System Path:${CLR_RESET} /var/lib/postgresql/17"
    echo -e "${CLR_WARN}[!] Warnings:${CLR_RESET} PRoot prevents normal service start scripts."
    echo -e "    We initialize it manually and manage starting/stopping via bashrc command aliases."
    
    # 1. Install APT Package
    echo -e "\n--- Step 1: Installing postgresql server ---"
    run_with_spinner "$SUDO apt update" "Syncing repositories"
    if ! check_apt_pkg "postgresql"; then
        run_with_spinner "$SUDO apt install -y postgresql" "Installing PostgreSQL package"
    else
        echo -e "${CLR_VAL}[✔]${CLR_RESET} postgresql package already installed."
    fi
    
    # 2. Setup storage directory & permissions
    echo -e "\n--- Step 2: Configuring postgres data cluster directory ---"
    $SUDO mkdir -p /var/lib/postgresql/17/main
    $SUDO chown -R postgres:postgres /var/lib/postgresql/17
    
    # 3. Initialize db cluster as postgres system user
    if [ ! -f "/var/lib/postgresql/17/main/PG_VERSION" ]; then
        run_with_spinner "$SUDO su -s /bin/bash postgres -c \"/usr/lib/postgresql/17/bin/initdb -D /var/lib/postgresql/17/main\"" \
            "Initializing PostgreSQL database cluster"
    else
        echo -e "${CLR_VAL}[✔]${CLR_RESET} PostgreSQL cluster already initialized."
    fi
    
    # 4. Add aliases for database control to ~/.bashrc
    echo -e "\n--- Step 3: Configuring bash control aliases ---"
    local postgres_block="# PostgreSQL Control Aliases
alias pgstart='su -s /bin/bash postgres -c \"/usr/lib/postgresql/17/bin/pg_ctl -D /var/lib/postgresql/17/main -l /var/log/postgresql/postgres.log start\"'
alias pgstop='su -s /bin/bash postgres -c \"/usr/lib/postgresql/17/bin/pg_ctl -D /var/lib/postgresql/17/main stop\"'
alias pgdb='su -s /bin/bash postgres -c \"psql\"'"

    if append_block_to_bashrc "POSTGRES" "$postgres_block"; then
        echo -e "${CLR_VAL}[✔]${CLR_RESET} Added database shortcuts to ~/.bashrc:"
        echo -e "    ${CLR_MENU}pgstart${CLR_RESET} -> Starts PostgreSQL Database Server"
        echo -e "    ${CLR_MENU}pgstop${CLR_RESET}  -> Stops Database Server"
        echo -e "    ${CLR_MENU}pgdb${CLR_RESET}    -> Opens the admin SQL command shell (psql)"
    fi
    
    # Attempt server start
    echo -e "\n--- Step 4: Starting PostgreSQL Database Service ---"
    $SUDO su -s /bin/bash postgres -c "/usr/lib/postgresql/17/bin/pg_ctl -D /var/lib/postgresql/17/main -l /var/log/postgresql/postgres.log start"
    
    echo -e "\n${CLR_VAL}✔ PostgreSQL Database Server setup complete!${CLR_RESET}"
    echo -e "${CLR_INFO}[*] Info:${CLR_RESET} You can run ${CLR_MENU}pgdb${CLR_RESET} now to configure schemas."
    echo -e "${CLR_WARN}[!] Action Needed:${CLR_RESET} Please run: ${CLR_MENU}source ~/.bashrc${CLR_RESET} to enable settings."
}

remove_postgresql_env() {
    echo -e "${CLR_WARN}[!] WARNING: You are about to remove PostgreSQL Database Server.${CLR_RESET}"
    echo -e "    This will stop the server, purge postgresql packages, and delete data clusters:"
    echo -e "    - /var/lib/postgresql"
    echo -ne "    Do you want to proceed? (y/N): "
    read -r response
    if [[ ! "$response" =~ ^[Yy]$ ]]; then
        echo -e "${CLR_ERR}Removal cancelled.${CLR_RESET}"
        return 1
    fi
    
    # Stop database server
    echo -e "${CLR_INFO}[➔] Stopping PostgreSQL service...${CLR_RESET}"
    $SUDO su -s /bin/bash postgres -c "/usr/lib/postgresql/17/bin/pg_ctl -D /var/lib/postgresql/17/main stop" >/dev/null 2>&1
    
    # Remove shortcuts
    remove_block_from_bashrc "POSTGRES"
    
    # Purge package and storage
    run_with_spinner "$SUDO apt purge -y postgresql" "Purging PostgreSQL package"
    run_with_spinner "$SUDO rm -rf /var/lib/postgresql" "Deleting PostgreSQL storage data"
    
    echo -e "${CLR_VAL}[✔] PostgreSQL Database Server successfully removed.${CLR_RESET}"
}

