# PROJECT INSTANTIATION & OFFLINE TOGGLE UTILITIES
# ==============================================================================

create_project_from_template() {
    local template="$1"
    local name="$2"
    
    if [ -z "$template" ] || [ -z "$name" ]; then
        echo -e "${CLR_ERR}[✘] Error: Specify a template and a new project name.${CLR_RESET}"
        echo -e "Usage: devenv-pocket create <template> <project-name>"
        echo -e "Available templates: ${CLR_MENU}react${CLR_RESET}, ${CLR_MENU}node${CLR_RESET}, ${CLR_MENU}flutter${CLR_RESET}"
        return 1
    fi
    
    local source_dir=""
    case "$template" in
        react) source_dir="$TEMPLATES_DIR/react-vite-ts" ;;
        node) source_dir="$TEMPLATES_DIR/node-postgres" ;;
        flutter) source_dir="$TEMPLATES_DIR/flutter-starter" ;;
        *)
            echo -e "${CLR_ERR}[✘] Error: Unknown template '$template'. Available: react, node, flutter.${CLR_RESET}"
            return 1
            ;;
    esac
    
    if [ ! -d "$source_dir" ]; then
        echo -e "${CLR_ERR}[✘] Error: Template '$template' is not cached locally.${CLR_RESET}"
        echo -e "Please configure Node or Flutter first and select 'y' to offline caching."
        return 1
    fi
    
    local target_dir="$PROJECTS_DIR/$name"
    if [ -d "$target_dir" ]; then
        echo -e "${CLR_ERR}[✘] Error: Target directory '$target_dir' already exists.${CLR_RESET}"
        return 1
    fi
    
    mkdir -p "$PROJECTS_DIR"
    echo -e "${CLR_INFO}[➔] Creating new project '$name' from template '$template'...${CLR_RESET}"
    
    # Content-addressable link duplicate copying
    cp -rp "$source_dir" "$target_dir"
    
    # Post-process configs based on template type
    if [ "$template" = "react" ] || [ "$template" = "node" ]; then
        # Rename package name in package.json
        if [ -f "$target_dir/package.json" ]; then
            sed -i 's/"name": ".*-template"/"name": "'"$name"'"/' "$target_dir/package.json"
        fi
    fi
    
    echo -e "\n${CLR_MENU}┌──────────────────────────────────────────────────────────────────────┐${CLR_RESET}"
    echo -e "${CLR_MENU}│${CLR_RESET} 🎉 ${CLR_TITLE}PROJECT STARTER SUCCESSFULLY INSTANTIATED!${CLR_RESET}                        ${CLR_MENU}│${CLR_RESET}"
    echo -e "${CLR_MENU}├──────────────────────────────────────────────────────────────────────┤${CLR_RESET}"
    echo -e "${CLR_MENU}│${CLR_RESET} Your project is ready offline in under 3 seconds!                     ${CLR_MENU}│${CLR_RESET}"
    echo -e "${CLR_MENU}│${CLR_RESET} Location: ${CLR_VAL}$target_dir${CLR_RESET}                                         ${CLR_MENU}│${CLR_RESET}"
    echo -e "${CLR_MENU}│${CLR_RESET}                                                                      ${CLR_MENU}│${CLR_RESET}"
    echo -e "${CLR_MENU}│${CLR_RESET} To start coding:                                                      ${CLR_MENU}│${CLR_RESET}"
    echo -e "${CLR_MENU}│${CLR_RESET}   ${CLR_MENU}cd $target_dir${CLR_RESET}                                                    ${CLR_MENU}│${CLR_RESET}"
    if [ "$template" = "react" ]; then
        echo -e "${CLR_MENU}│${CLR_RESET}   ${CLR_MENU}pnpm dev${CLR_RESET} (Vite server starts offline instantly)                 ${CLR_MENU}│${CLR_RESET}"
    elif [ "$template" = "node" ]; then
        echo -e "${CLR_MENU}│${CLR_RESET}   ${CLR_MENU}pnpm start${CLR_RESET}                                                      ${CLR_MENU}│${CLR_RESET}"
    elif [ "$template" = "flutter" ]; then
        echo -e "${CLR_MENU}│${CLR_RESET}   ${CLR_MENU}flutter run${CLR_RESET}                                                 ${CLR_MENU}│${CLR_RESET}"
    fi
    echo -e "${CLR_MENU}└──────────────────────────────────────────────────────────────────────┘${CLR_RESET}"
}

toggle_offline_mode() {
    local state="$1"
    local gradle_props="$HOME/.gradle/gradle.properties"
    
    if [ -z "$state" ]; then
        if [ -f "$gradle_props" ] && grep -qF "org.gradle.offline=true" "$gradle_props"; then
            echo -e "Gradle Offline Mode is currently: ${CLR_VAL}ON${CLR_RESET}"
        else
            echo -e "Gradle Offline Mode is currently: ${CLR_ERR}OFF${CLR_RESET}"
        fi
        echo -e "Usage: devenv-pocket offline [on | off]"
        return 0
    fi
    
    mkdir -p "$(dirname "$gradle_props")"
    touch "$gradle_props"
    
    if [ "$state" = "on" ]; then
        sed -i '/org.gradle.offline/d' "$gradle_props"
        echo "org.gradle.offline=true" >> "$gradle_props"
        echo -e "${CLR_VAL}[✔] Gradle Offline Mode enabled (org.gradle.offline=true).${CLR_RESET}"
        echo -e "    Gradle will now build applications strictly from local caches."
    elif [ "$state" = "off" ]; then
        sed -i '/org.gradle.offline/d' "$gradle_props"
        echo -e "${CLR_VAL}[✔] Gradle Offline Mode disabled.${CLR_RESET}"
    else
        echo -e "${CLR_ERR}[✘] Error: Unknown state '$state'. Available: on, off.${CLR_RESET}"
    fi
}

