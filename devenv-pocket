#!/bin/bash
# ==============================================================================
# devenv-pocket
# 
# A developer environment installer for proot-distro environments (e.g. Ubuntu on Termux)
# Optimized for ARM64 processors. Supports interactive wizard and CLI arguments.
# ==============================================================================

# Exit on immediate keyboard interrupt
trap 'echo -e "\n\e[31m[!] Script interrupted by user. Exiting...\e[0m"; exit 1' INT

# Global configurations
TOOLS_DIR="$HOME/tools"
PROJECTS_DIR="$HOME/projects"
TEMPLATES_DIR="$PROJECTS_DIR/templates"
DEVENVS_LOG="/tmp/devenv_pocket_install.log"

# Define Theme Colors (ANSI escape sequences)
CLR_TITLE="\e[1;36m"   # Bold Cyan
CLR_MENU="\e[36m"    # Cyan
CLR_TEXT="\e[37m"    # White
CLR_VAL="\e[32m"     # Green
CLR_ERR="\e[1;31m"   # Bold Red
CLR_WARN="\e[1;33m"  # Bold Yellow
CLR_INFO="\e[34m"    # Blue
CLR_RESET="\e[0m"     # Reset

# Global CLI modes overrides (set by parameters)
CLI_MODE=""
CLI_EDITOR=""
CLI_OFFLINE=""

# Determine privilege wrapper (sudo or direct root)
SUDO=""
if [ "$(id -u)" -ne 0 ]; then
    if command -v sudo >/dev/null 2>&1; then
        SUDO="sudo"
    else
        echo -e "${CLR_ERR}[✘] Error: You are not running as root and 'sudo' is not installed.${CLR_RESET}"
        echo -e "Please run this script inside your proot-distro as root, or install 'sudo' first."
        exit 1
    fi
fi

# Print beautiful centered banners
draw_line() {
    local char="${1:-─}"
    local width=70
    printf "${CLR_MENU}"
    for ((i=0; i<width; i++)); do printf "%s" "$char"; done
    printf "${CLR_RESET}\n"
}

print_header() {
    clear
    draw_line "═"
    echo -e "   ${CLR_TITLE}___                               ____             _        ${CLR_RESET}"
    echo -e "  ${CLR_TITLE}/ _ \\\___ _  _____ _ __  __  __    /  _ \\ ___  ____ | | _ ___ ${CLR_RESET}"
    echo -e " ${CLR_TITLE}/ // / -_) |/ / -_) '  \\ \\ \\/ /   /  __ // _ \\/ __/ | |/ / -_)${CLR_RESET}"
    echo -e "${CLR_TITLE}/____/\\__/\\___/\\__/_/_/_/  \\_/    /_/    \\___/\\__/_  |___/\\__/ ${CLR_RESET}"
    echo -e "                                                  ${CLR_TITLE}/_/          ${CLR_RESET}"
    echo -e "         ${CLR_WARN}★ Rapid ARM64 proot-distro Dev Environment Suite ★${CLR_RESET}"
    draw_line "═"
    echo -e "${CLR_INFO}[i] GitHub recommendation: groot-desk for visual display setup:${CLR_RESET}"
    echo -e "    https://github.com/JeisonRoblero/groot-desk"
    draw_line "─"
}

# General interactive spinner for background tasks
run_with_spinner() {
    local cmd="$1"
    local msg="$2"
    
    # Empty log file
    : > "$DEVENVS_LOG"
    
    # Run command in background
    eval "$cmd" > "$DEVENVS_LOG" 2>&1 &
    local pid=$!
    local spin='-\|/'
    local i=0
    
    while kill -0 $pid 2>/dev/null; do
        i=$(( (i+1) % 4 ))
        printf "\r${CLR_MENU}[%c]${CLR_RESET} %s..." "${spin:$i:1}" "$msg"
        sleep 0.1
    done
    
    wait $pid
    local exit_code=$?
    
    if [ $exit_code -ne 0 ]; then
        printf "\r${CLR_ERR}[✘]${CLR_RESET} %s (Failed with code %d)\n" "$msg" "$exit_code"
        echo -e "${CLR_WARN}--- Installation log error output ---${CLR_RESET}"
        tail -n 15 "$DEVENVS_LOG"
        echo -e "${CLR_WARN}-------------------------------------${CLR_RESET}"
        return $exit_code
    else
        printf "\r${CLR_VAL}[✔]${CLR_RESET} %s (Completed successfully)\n" "$msg"
        return 0
    fi
}

# Download helper with native wget progress bar
download_file() {
    local url="$1"
    local dest="$2"
    local name="$3"
    
    echo -e "${CLR_INFO}[➔]${CLR_RESET} Downloading $name..."
    echo -e "    Source: $url"
    echo -e "    Destination: $dest"
    
    # Ensure folder containing destination exists
    mkdir -p "$(dirname "$dest")"
    
    # Download using wget with a progress bar
    wget -O "$dest" --show-progress "$url"
    local exit_code=$?
    
    if [ $exit_code -ne 0 ]; then
        echo -e "${CLR_ERR}[✘] Error downloading $name (exit code: $exit_code)${CLR_RESET}"
        return $exit_code
    fi
    echo -e "${CLR_VAL}[✔] Downloaded $name.${CLR_RESET}"
    return 0
}

# Helpers to manage blocks in ~/.bashrc safely and cleanly
append_block_to_bashrc() {
    local marker="$1"
    local block="$2"
    local bashrc="$HOME/.bashrc"
    
    touch "$bashrc"
    if grep -qF "# === START DEVENV-POCKET $marker ===" "$bashrc" 2>/dev/null; then
        return 1 # already exists
    fi
    
    echo -e "\n# === START DEVENV-POCKET $marker ===\n$block\n# === END DEVENV-POCKET $marker ===" >> "$bashrc"
    return 0
}

remove_block_from_bashrc() {
    local marker="$1"
    local bashrc="$HOME/.bashrc"
    
    if [ -f "$bashrc" ] && grep -qF "# === START DEVENV-POCKET $marker ===" "$bashrc" 2>/dev/null; then
        # Delete lines between markers inclusive
        sed -i "/# === START DEVENV-POCKET $marker ===/,/# === END DEVENV-POCKET $marker ===/d" "$bashrc"
        return 0
    fi
    return 1
}

# Detect specific package installation
check_apt_pkg() {
    dpkg -s "$1" >/dev/null 2>&1
    return $?
}

# System diagnostics information
get_free_space() {
    df -h "$HOME" | awk 'NR==2 {print $4}'
}

get_system_info() {
    local arch; arch=$(uname -m)
    local distro; distro="Unknown Linux"
    if [ -f /etc/os-release ]; then
        distro=$(grep '^PRETTY_NAME=' /etc/os-release | cut -d= -f2 | tr -d '"')
    fi
    local user; user=$(whoami)
    local space; space=$(get_free_space)
    
    echo -e "┌──────────────────────────────────────────────────────────────────────┐"
    echo -e "│ ${CLR_TITLE}SYSTEM DETAILS${CLR_RESET}                                                       │"
    echo -e "├──────────────────────────────────────────────────────────────────────┤"
    printf "│ %-14s : %-51s │\n" "Distribution" "$distro"
    printf "│ %-14s : %-51s │\n" "Architecture" "$arch"
    printf "│ %-14s : %-51s │\n" "Active User" "$user"
    printf "│ %-14s : %-51s │\n" "Disk Available" "$space"
    echo -e "└──────────────────────────────────────────────────────────────────────┘"
}

