# ==============================================================================
# ENVIRONMENT 1: NODE.JS & WEB DEVELOPMENT
# ==============================================================================

check_node_web_status() {
    local missing_base=0
    local base_pkgs=(curl git unzip xz-utils zip wget nodejs npm)
    for pkg in "${base_pkgs[@]}"; do
        if ! check_apt_pkg "$pkg"; then
            ((missing_base++))
        fi
    done
    
    local has_pnpm=0
    if command -v pnpm >/dev/null 2>&1; then
        has_pnpm=1
    fi
    
    if [ $missing_base -eq 0 ] && [ $has_pnpm -eq 1 ]; then
        echo -e "${CLR_VAL}[Installed]${CLR_RESET}"
    elif [ $missing_base -ne 0 ] && [ $has_pnpm -eq 0 ]; then
        echo -e "${CLR_ERR}[Not Installed]${CLR_RESET}"
    else
        echo -e "${CLR_WARN}[Partially Installed]${CLR_RESET}"
    fi
}

configure_offline_web_templates() {
    echo -e "\n${CLR_TITLE}Setting up Offline Web Caching & Templates...${CLR_RESET}"
    mkdir -p "$TEMPLATES_DIR"
    
    # 1. React Vite TS Template
    local r_dir="$TEMPLATES_DIR/react-vite-ts"
    if [ ! -d "$r_dir" ]; then
        echo -e "  Creating React + Vite + TypeScript Template..."
        mkdir -p "$r_dir/src"
        
        # package.json
        cat > "$r_dir/package.json" << 'EOF'
