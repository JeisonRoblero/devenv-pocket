    if [ -d "$TOOLS_DIR/android-sdk/platforms/android-34" ]; then echo -e "${CLR_VAL}Installed${CLR_RESET}"; else echo -e "${CLR_ERR}Missing${CLR_RESET}"; fi
    
    printf " %-30s : " "Custom ARM64 NDK r28c"
    if [ -d "$TOOLS_DIR/android-sdk/ndk/28.2.13676358" ]; then echo -e "${CLR_VAL}Installed${CLR_RESET}"; else echo -e "${CLR_ERR}Missing${CLR_RESET}"; fi
    
    printf " %-30s : " "code-server (VS Code web)"
    if command -v code-server >/dev/null 2>&1; then echo -e "${CLR_VAL}Available${CLR_RESET}"; else echo -e "${CLR_ERR}Missing${CLR_RESET}"; fi
    
    printf " %-30s : " "PostgreSQL Service Shell"
    if [ -f "/var/lib/postgresql/17/main/PG_VERSION" ]; then echo -e "${CLR_VAL}Active${CLR_RESET}"; else echo -e "${CLR_ERR}Missing${CLR_RESET}"; fi
    
    printf " %-30s : " "Offline Project Templates"
    local t_count=0
    for t in react-vite-ts node-postgres flutter-starter; do
        if [ -d "$TEMPLATES_DIR/$t" ]; then ((t_count++)); fi
